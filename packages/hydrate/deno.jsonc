{
  "name": "@ggpwnkthx/dom-hydrate",
  "version": "0.0.1-rc.3",
  "exports": {
    ".": "./src/mod.ts"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1",
    "@b-fuze/deno-dom": "jsr:@b-fuze/deno-dom@^0.1",
    "@ggpwnkthx/dom-shared": "jsr:@ggpwnkthx/dom-shared@^0.0.1-rc.3",
    "@ggpwnkthx/jsx": "jsr:@ggpwnkthx/jsx@^0.1"
  },
  "fmt": {
    "lineWidth": 88,
    "indentWidth": 2,
    "useTabs": false,
    "semiColons": true,
    "singleQuote": false,
    "proseWrap": "preserve",
    "trailingCommas": "onlyMultiLine",
    "operatorPosition": "nextLine"
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  },
  "compilerOptions": {
    "strict": true
  },
  "exclude": [".*", "coverage"]
}
