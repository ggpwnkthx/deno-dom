{
  "name": "@ggpwnkthx/dom",
  "version": "0.0.1-rc.5",
  "exports": {
    ".": "./src/mod.ts"
  },
  "imports": {
    "@std/assert@1.0.19": "jsr:@std/assert@1.0.19"
  },
  "workspace": [
    "./packages/shared",
    "./packages/runtime",
    "./packages/hydrate",
    "./packages/scheduler"
  ],
  "fmt": {
    "lineWidth": 88,
    "indentWidth": 2,
    "useTabs": false,
    "semiColons": true,
    "singleQuote": false,
    "proseWrap": "preserve",
    "trailingCommas": "onlyMultiLine",
    "operatorPosition": "nextLine"
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  },
  "compilerOptions": {
    "strict": true
  },
  "tasks": {
    "test": "deno test --allow-read --coverage=coverage ./tests",
    "bench": "deno bench ./benchmarks",
    "fmt": "deno fmt",
    "lint": "deno lint ./src ./tests ./benchmarks",
    "check": "deno check ./src/mod.ts",
    "ci": "deno task fmt && deno task lint --fix && deno task check && deno task test",
    "test:smoke": "deno test --allow-read ./tests/smoke_test.ts"
  },
  "exclude": [".*", "coverage"]
}
